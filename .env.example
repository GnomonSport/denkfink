# Root .env for docker-compose. Copy to `.env`, fill in, then `docker compose up`.
# Each app's own .env.example covers running that app alone (see apps/*/.env.example).
# Values here are interpolated into docker-compose.yml at build + run time.

# --- Shared Supabase (same project across all services) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Anon key — safe to bake into browser bundles.
VITE_SUPABASE_ANON_KEY=

# Service role key — server-side only. NEVER expose via Vite (no VITE_ prefix).
SUPABASE_SERVICE_ROLE_KEY=

# --- ElevenLabs ---
# Tablet uses the browser key; backend + extract script use the same account.
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_AGENT_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- LLM / embeddings ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- Print renderer ---
# Any long random string; clients must send it as X-Api-Key.
RENDER_API_KEY=dev-key

# --- Archive (optional) ---
# Public URL of the deployed archive app. Leave blank to skip QR codes
# on printed cards and skip archive linking in the print-renderer.
VITE_ARCHIVE_BASE=
